generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           String                 @id @default(uuid())
  name         String
  settings     Json?                  @default("{}")
  createdAt    DateTime               @default(now())
  categories   Category[]
  customers    Customer[]
  dispatches   DispatchOrder[]
  inventory    Inventory[]            @relation("CompanyToInventory")
  transactions InventoryTransaction[]
  activityLogs ActivityLog[]
  items        Item[]
  pos          PurchaseOrder[]
  racks        Rack[]
  stocks       Stock[]                @relation("CompanyToStock")
  users        User[]
  vendors      Vendor[]
}

model User {
  id               String                 @id @default(uuid())
  username         String                 @unique
  password         String
  name             String
  emailAlerts      Boolean                @default(true)
  twoFactorEnabled Boolean                @default(false)
  createdAt        DateTime               @default(now())
  companyId        String?
  role             UserRole               @default(EMPLOYEE)
  customPermissions String[]              @default([])
  batches          InventoryBatch[]
  transactions     InventoryTransaction[]
  company          Company?               @relation(fields: [companyId], references: [id])
}

model Category {
  id        String  @id @default(uuid())
  name      String
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  items     Item[]

  @@unique([name, companyId])
}

model Item {
  id            String                 @id @default(uuid())
  name          String
  sku           String
  categoryId    String
  unit          String
  createdAt     DateTime               @default(now())
  isCritical    Boolean                @default(false)
  minStockLevel Decimal                @default(0) @db.Decimal(18, 4)
  companyId     String
  dispatchItems DispatchItem[]
  inventory     Inventory?
  transactions  InventoryTransaction[]
  category      Category               @relation(fields: [categoryId], references: [id])
  company       Company                @relation(fields: [companyId], references: [id])
  poItems       POLineItem[]
  stocks        Stock[]

  @@unique([sku, companyId])
}

model Rack {
  id           String                 @id @default(uuid())
  rackNumber   String
  zone         String?
  companyId    String
  transactions InventoryTransaction[]
  company      Company                @relation(fields: [companyId], references: [id])
  stocks       Stock[]

  @@unique([rackNumber, companyId])
}

model Stock {
  id        String   @id @default(uuid())
  itemId    String
  rackId    String
  quantity  Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation("CompanyToStock", fields: [companyId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])
  rack      Rack     @relation(fields: [rackId], references: [id])

  @@index([itemId])
  @@index([rackId])
  @@index([companyId])
}

model Inventory {
  id                String           @id @default(uuid())
  itemId            String           @unique
  quantityAvailable Decimal            @default(0) @db.Decimal(18, 4)
  incomingQty       Decimal            @default(0) @db.Decimal(18, 4)
  quantityReserved  Decimal            @default(0) @db.Decimal(18, 4)
  quantityInTransit Decimal            @default(0) @db.Decimal(18, 4)
  quantityQC        Decimal            @default(0) @db.Decimal(18, 4)
  updatedAt         DateTime         @updatedAt
  companyId         String
  company           Company          @relation("CompanyToInventory", fields: [companyId], references: [id])
  item              Item             @relation(fields: [itemId], references: [id])
  batches           InventoryBatch[]

  @@index([companyId])
}

model Vendor {
  id                   String                 @id @default(uuid())
  name                 String
  contact              String?
  email                String?
  preferredPaymentMode String?                @default("Cash")
  companyId            String
  batches              InventoryBatch[]
  transactions         InventoryTransaction[]
  purchaseOrders       PurchaseOrder[]
  company              Company                @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
}

model PurchaseOrder {
  id               String           @id @default(uuid())
  vendorId         String
  status           String           @default("DRAFT")
  paymentMode      String?          @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime         @default(now())
  createdAt        DateTime         @default(now())
  paymentStatus    String           @default("PENDING")
  companyId        String
  batches          InventoryBatch[]
  items            POLineItem[]
  company          Company          @relation(fields: [companyId], references: [id])
  vendor           Vendor           @relation(fields: [vendorId], references: [id])

  @@index([status])
  @@index([vendorId])
  @@index([companyId])
}

model InventoryBatch {
  id              String         @id @default(uuid())
  inventoryId     String
  vendorId        String
  quantity        Decimal        @db.Decimal(18, 4)
  remainingQty    Decimal        @db.Decimal(18, 4)
  costPerUnit     Decimal        @db.Decimal(18, 4)
  purchaseDate    DateTime
  purchaseOrderId String?
  createdAt       DateTime       @default(now())
  receivedById    String?
  inventory       Inventory      @relation(fields: [inventoryId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receivedBy      User?          @relation(fields: [receivedById], references: [id])
  vendor          Vendor         @relation(fields: [vendorId], references: [id])

  @@index([purchaseOrderId, inventoryId])
  @@index([inventoryId, purchaseDate])
  @@index([vendorId])
}

model POLineItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  itemId           String
  quantityOrdered  Decimal       @db.Decimal(18, 4)
  quantityReceived Decimal       @default(0) @db.Decimal(18, 4)
  costPrice        Decimal       @db.Decimal(18, 4)
  item             Item          @relation(fields: [itemId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Customer {
  id             String                 @id @default(uuid())
  name           String
  email          String?
  contact        String?
  address        String?
  companyId      String
  createdAt      DateTime               @default(now())
  company        Company                @relation(fields: [companyId], references: [id])
  dispatchOrders DispatchOrder[]
  transactions   InventoryTransaction[]

  @@unique([name, companyId])
}

model DispatchOrder {
  id               String         @id @default(uuid())
  customerId       String
  status           String         @default("pending")
  paymentMode      String?        @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime       @default(now())
  createdAt        DateTime       @default(now())
  companyId        String
  collectedBy      String?
  dispatchedBy     String?
  transportMode    String?
  items            DispatchItem[]
  company          Company        @relation(fields: [companyId], references: [id])
  customer         Customer       @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([companyId])
}

model DispatchItem {
  id              String        @id @default(uuid())
  dispatchOrderId String
  itemId          String
  quantity        Decimal       @db.Decimal(18, 4)
  sellingPrice    Decimal       @db.Decimal(18, 4)
  dispatchOrder   DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  item            Item          @relation(fields: [itemId], references: [id])
}

model InventoryTransaction {
  id            String    @id @default(uuid())
  itemId        String
  rackId        String?
  userId        String?
  customerId    String?
  vendorId      String?
  type          String
  quantity      Decimal   @db.Decimal(18, 4)
  referenceType String?
  referenceId   String?
  createdAt     DateTime  @default(now())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])
  item          Item      @relation(fields: [itemId], references: [id])
  rack          Rack?     @relation(fields: [rackId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
  @@index([companyId])
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  EMPLOYEE
}

model ActivityLog {
  id              String   @id @default(uuid())
  actionType      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType      String   // Item, Vendor, PO, User, etc.
  entityId        String?
  performedBy     String   // User ID
  performedByName String
  oldValue        Json?    @default("{}")
  newValue        Json?    @default("{}")
  changedFields   Json?    @default("[]")
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])

  @@index([createdAt])
  @@index([entityId])
  @@index([performedBy])
  @@index([companyId])
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  subdomain String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  roles                 Role[]
  categories            Category[]
  items                 Item[]
  racks                 Rack[]
  stocks                Stock[]
  inventories           Inventory[]
  vendors               Vendor[]
  purchaseOrders        PurchaseOrder[]
  inventoryBatches      InventoryBatch[]
  poLineItems           POLineItem[]
  customers             Customer[]
  dispatchOrders        DispatchOrder[]
  dispatchItems         DispatchItem[]
  inventoryTransactions InventoryTransaction[]
}

model User {
  id               String                 @id @default(uuid())
  tenantId         String                 @map("tenant_id")
  username         String
  password         String
  name             String
  role             String                 @default("employee")
  roleId           String?                @map("role_id")
  roleObj          Role?                  @relation(fields: [roleId], references: [id])
  emailAlerts      Boolean                @default(true)
  twoFactorEnabled Boolean                @default(false)
  createdAt        DateTime               @default(now())
  transactions     InventoryTransaction[]
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, username])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  permissions Json?    @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model Category {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  items    Item[]
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model Item {
  id            String                 @id @default(uuid())
  tenantId      String                 @map("tenant_id")
  name          String
  sku           String
  categoryId    String
  unit          String
  createdAt     DateTime               @default(now())
  isCritical    Boolean                @default(false)
  minStockLevel Float                  @default(0)
  dispatchItems DispatchItem[]
  inventory     Inventory?
  transactions  InventoryTransaction[]
  category      Category               @relation(fields: [categoryId], references: [id])
  poItems       POLineItem[]
  stocks        Stock[]
  tenant        Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sku])
}

model Rack {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  rackNumber   String
  zone         String?
  stocks       Stock[]
  transactions InventoryTransaction[]
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, rackNumber])
}

model Stock {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  itemId    String
  rackId    String
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  item      Item     @relation(fields: [itemId], references: [id])
  rack      Rack     @relation(fields: [rackId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([itemId])
  @@index([rackId])
  @@index([tenantId])
}

model Inventory {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  itemId            String           @unique
  quantityAvailable Float            @default(0)
  incomingQty       Float            @default(0)
  quantityReserved  Float            @default(0)
  quantityInTransit Float            @default(0)
  updatedAt         DateTime         @updatedAt
  item              Item             @relation(fields: [itemId], references: [id])
  batches           InventoryBatch[]
  tenant            Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Vendor {
  id                   String                 @id @default(uuid())
  tenantId             String                 @map("tenant_id")
  name                 String
  contact              String?
  email                String?
  preferredPaymentMode String?                @default("Cash")
  purchaseOrders       PurchaseOrder[]
  transactions         InventoryTransaction[]
  batches              InventoryBatch[]
  tenant               Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model PurchaseOrder {
  id               String           @id @default(uuid())
  tenantId         String           @map("tenant_id")
  vendorId         String
  status           String           @default("DRAFT")
  paymentMode      String?          @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime         @default(now())
  createdAt        DateTime         @default(now())
  vendor           Vendor           @relation(fields: [vendorId], references: [id])
  items            POLineItem[]
  batches          InventoryBatch[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([vendorId])
  @@index([tenantId])
}

model InventoryBatch {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  inventoryId     String
  vendorId        String
  quantity        Float
  remainingQty    Float
  costPerUnit     Float
  purchaseDate    DateTime
  purchaseOrderId String?
  createdAt       DateTime @default(now())

  inventory     Inventory      @relation(fields: [inventoryId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([purchaseOrderId, inventoryId])
  @@index([inventoryId, purchaseDate])
  @@index([vendorId])
  @@index([tenantId])
}

model POLineItem {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  purchaseOrderId  String
  itemId           String
  quantityOrdered  Float
  quantityReceived Float         @default(0)
  costPrice        Float
  item             Item          @relation(fields: [itemId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Customer {
  id             String                 @id @default(uuid())
  tenantId       String                 @map("tenant_id")
  name           String
  email          String?
  contact        String?
  address        String?
  dispatchOrders DispatchOrder[]
  transactions   InventoryTransaction[]
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model DispatchOrder {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  customerId       String
  status           String         @default("pending")
  paymentMode      String?        @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime       @default(now())
  createdAt        DateTime       @default(now())
  items            DispatchItem[]
  customer         Customer       @relation(fields: [customerId], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([tenantId])
}

model DispatchItem {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  dispatchOrderId String
  itemId          String
  quantity        Float
  sellingPrice    Float
  dispatchOrder   DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  item            Item          @relation(fields: [itemId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model InventoryTransaction {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  itemId        String
  rackId        String?
  userId        String?
  customerId    String?
  vendorId      String?
  type          String
  quantity      Float
  referenceType String?
  referenceId   String?
  createdAt     DateTime  @default(now())
  item          Item      @relation(fields: [itemId], references: [id])
  rack          Rack?     @relation(fields: [rackId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId])
}

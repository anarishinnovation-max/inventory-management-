generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(uuid())
  username         String                 @unique
  password         String
  name             String
  role             String                 @default("employee")
  roleId           String?                @map("role_id")
  roleObj          Role?                  @relation(fields: [roleId], references: [id])
  emailAlerts      Boolean                @default(true)
  twoFactorEnabled Boolean                @default(false)
  createdAt        DateTime               @default(now())
  transactions     InventoryTransaction[]
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json?    @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  items Item[]
}

model Item {
  id            String                 @id @default(uuid())
  name          String
  sku           String                 @unique
  categoryId    String
  unit          String
  createdAt     DateTime               @default(now())
  isCritical    Boolean                @default(false)
  minStockLevel Float                  @default(0)
  dispatchItems DispatchItem[]
  inventory     Inventory?
  transactions  InventoryTransaction[]
  category      Category               @relation(fields: [categoryId], references: [id])
  poItems       POLineItem[]
  stocks        Stock[]
}

model Rack {
  id           String                 @id @default(uuid())
  rackNumber   String                 @unique
  zone         String?
  stocks       Stock[]
  transactions InventoryTransaction[]
}

model Stock {
  id        String   @id @default(uuid())
  itemId    String
  rackId    String
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  item      Item     @relation(fields: [itemId], references: [id])
  rack      Rack     @relation(fields: [rackId], references: [id])

  @@index([itemId])
  @@index([rackId])
}

model Inventory {
  id                String           @id @default(uuid())
  itemId            String           @unique
  quantityAvailable Float            @default(0)
  incomingQty       Float            @default(0)
  quantityReserved  Float            @default(0)
  quantityInTransit Float            @default(0)
  updatedAt         DateTime         @updatedAt
  item              Item             @relation(fields: [itemId], references: [id])
  batches           InventoryBatch[]
}

model Vendor {
  id                   String                 @id @default(uuid())
  name                 String                 @unique
  contact              String?
  email                String?
  preferredPaymentMode String?                @default("Cash")
  purchaseOrders       PurchaseOrder[]
  transactions         InventoryTransaction[]
  batches              InventoryBatch[]
}

model PurchaseOrder {
  id               String           @id @default(uuid())
  vendorId         String
  status           String           @default("DRAFT")
  paymentMode      String?          @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime         @default(now())
  createdAt        DateTime         @default(now())
  vendor           Vendor           @relation(fields: [vendorId], references: [id])
  items            POLineItem[]
  batches          InventoryBatch[]

  @@index([status])
  @@index([vendorId])
}

model InventoryBatch {
  id              String   @id @default(uuid())
  inventoryId     String
  vendorId        String
  quantity        Float
  remainingQty    Float
  costPerUnit     Float
  purchaseDate    DateTime
  purchaseOrderId String?
  createdAt       DateTime @default(now())

  inventory     Inventory      @relation(fields: [inventoryId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@unique([purchaseOrderId, inventoryId])
  @@index([inventoryId, purchaseDate])
  @@index([vendorId])
}

model POLineItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  itemId           String
  quantityOrdered  Float
  quantityReceived Float         @default(0)
  costPrice        Float
  item             Item          @relation(fields: [itemId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Customer {
  id             String                 @id @default(uuid())
  name           String
  email          String?
  contact        String?
  address        String?
  dispatchOrders DispatchOrder[]
  transactions   InventoryTransaction[]
}

model DispatchOrder {
  id               String         @id @default(uuid())
  customerId       String
  status           String         @default("pending")
  paymentMode      String?        @default("Cash")
  expectedDelivery DateTime?
  orderDate        DateTime       @default(now())
  createdAt        DateTime       @default(now())
  items            DispatchItem[]
  customer         Customer       @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([customerId])
}

model DispatchItem {
  id              String        @id @default(uuid())
  dispatchOrderId String
  itemId          String
  quantity        Float
  sellingPrice    Float
  dispatchOrder   DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  item            Item          @relation(fields: [itemId], references: [id])
}

model InventoryTransaction {
  id            String    @id @default(uuid())
  itemId        String
  rackId        String?
  userId        String?
  customerId    String?
  vendorId      String?
  type          String
  quantity      Float
  referenceType String?
  referenceId   String?
  createdAt     DateTime  @default(now())
  item          Item      @relation(fields: [itemId], references: [id])
  rack          Rack?     @relation(fields: [rackId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
}
